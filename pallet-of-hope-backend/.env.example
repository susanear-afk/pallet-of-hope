# ================================
# PALLET OF HOPE — ENV CONFIG
# Copy this file to .env and fill in your values
# ================================

# Server
PORT=3000

# Email — Gmail SMTP (recommended to start)
# Use an App Password, NOT your regular Gmail password
# Get one at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-foundation-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=The Giving Pallet Foundation <your-foundation-email@gmail.com>

# Foundation admin email (where new applications are sent)
ADMIN_EMAIL=admin@palletofhope.org

# App base URL (used in emails)
BASE_URL=http://localhost:3000

# Admin Dashboard Security
# Set a strong password — only you and your co-founder should know this
ADMIN_PASSWORD=your-strong-password-here
# Set a random secret token (any random string of letters and numbers)
ADMIN_TOKEN=your-random-secret-token-here
